# --- Server ---
NODE_ENV=development
PORT=3000
# Comma-separated origins (allowed for CORS + Better-Auth trustedOrigins)
FRONTEND_ORIGIN=http://localhost:5173

# --- Database (matches docker-compose at repo root) ---
DATABASE_URL=postgres://ticketapp:ticketapp_dev@localhost:5432/ticketapp

# --- Better-Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me_with_random_32_byte_secret
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# --- Admin bootstrap ---
# First user to register/login with this email is auto-promoted to admin role.
INITIAL_ADMIN_EMAIL=
# Comma-separated CIDRs that bypass DB ip_allowlist check (use only for first login)
# Example: 127.0.0.1/32,::1/128
ADMIN_IP_BOOTSTRAP=127.0.0.1/32,::1/128

# --- Trusted proxy ---
# Only honor X-Forwarded-For / CF-Connecting-IP / X-Real-IP when the direct
# peer is in this list. Empty = ignore forwarded headers entirely (safe for
# direct local dev). For production behind Cloudflare set the CF egress ranges:
# https://www.cloudflare.com/ips-v4 + ips-v6
TRUSTED_PROXY_CIDRS=

# --- First-topup bonus (optional) ---
# Apply a percentage bonus to a user's first ever topup. Empty/0 = disabled.
FIRST_TOPUP_BONUS_PERCENT=
FIRST_TOPUP_BONUS_MAX=100

# --- Object storage (Cloudflare R2 / MinIO / AWS S3) ---
# All product images are uploaded here at runtime.
# For Cloudflare R2:
#   S3_ENDPOINT      = https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION        = auto
#   S3_PUBLIC_URL    = https://images.k4ecubby.dev   (custom domain on the bucket)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=cubbystore
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
